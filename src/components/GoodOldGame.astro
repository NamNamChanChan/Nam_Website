---
import config from "@/config";
import { getAssetPath } from "@/utils/withBase";

const locale = Astro.currentLocale ?? config.site.lang;
const isZh = locale === "zh";
const ruffleScript = getAssetPath("vendor/ruffle/ruffle.js");
const previewImage = getAssetPath("games/whtbb/preview.png");
const swfUrl = getAssetPath(
  "games/whtbb/brain_game_2_6_7_translated_v1.swf"
);

const copy = isZh
  ? {
      intro:
        "把舊互聯網的一小角保存下來。這款 2009 年的 Facebook Flash 遊戲和模擬器都存放在本站，無需依賴外部服務，也可以在現代瀏覽器直接玩。",
      playHint: "點一下遊戲畫面開始。建議使用桌面瀏覽器和滑鼠。",
      playLabel: "開始遊戲",
      loadError: "遊戲載入失敗。請重新整理頁面再試一次。",
      offlineTitle: "離線保存版本",
      offlineNote:
        "這個修復版本可以遊玩，但原本依賴 Facebook 伺服器的統計、挑戰和排行榜功能不會運作。",
      attribution:
        "Who Has The Biggest Brain? 由 Playfish 在 2009 年推出；Playfish 後來被 EA 收購，遊戲亦隨 Facebook 版本停止服務而消失。本站保存的是社群修復的離線版本。",
      creditsTitle: "是誰把這款遊戲帶回來？",
      creditsIntro:
        "這個可以遊玩的版本不是憑空出現。以下幾位保存者接力找回檔案、修改遊戲，讓它在原有伺服器關閉多年後仍可運行：",
      pandaRole:
        "保存並上載遊戲，修改程式讓它可以完全離線運行，也是 Internet Archive 保存項目的上載者。",
      rachidRole:
        "提供最重要的遊戲主檔案，令這次修復有可能開始。",
      alejandroRole: "協助修復遊戲內的多個 glitch。",
      ruffleRole:
        "開發並維護開源 Flash 模擬器，讓保存下來的 SWF 可以在現代瀏覽器運行。本站使用本地保存的 Ruffle。",
      updateTitle: "保存項目記錄的更新（9/8/25）",
      updateItems: [
        "修正 Car Path 正確符號消失的問題。",
        "參考 iPhone 版本，為 Hexagon Path 加入重設程序。",
        "移除已經失效、只在橫向模式出現的計分板。",
        "移除上載分數的彈出視窗。",
      ],
      creditNote:
        "我們只是再保存一份本地副本。真正把遊戲帶回來的功勞，屬於以上保存者和持續維護 Ruffle 的貢獻者。",
      archiveLink: "查看原始保存來源",
      fallback: "這款遊戲需要 JavaScript 才能運行。",
    }
  : {
      intro:
        "A small corner of the old web, kept alive. This 2009 Facebook Flash game and its emulator are stored on this site, so it runs in a modern browser without depending on an external service.",
      playHint:
        "Click inside the game to start. A desktop browser and mouse work best.",
      playLabel: "Play preserved game",
      loadError: "The game could not load. Please refresh the page and try again.",
      offlineTitle: "Offline preservation build",
      offlineNote:
        "The restored game is playable, but statistics, challenges and leaderboards that depended on Facebook's old servers do not work.",
      attribution:
        "Who Has The Biggest Brain? was released by Playfish in 2009. Playfish was later acquired by EA, and the game disappeared when its Facebook service was shut down. This site keeps a local copy of the community-restored offline build.",
      creditsTitle: "Who brought this game back?",
      creditsIntro:
        "This playable build did not appear by itself. A small chain of preservation work recovered the file, repaired the game and kept it running years after its original servers disappeared:",
      pandaRole:
        "archived and uploaded the game, modified it to work fully offline, and published the preservation item on Internet Archive.",
      rachidRole:
        "provided the essential main game file that made the recovery possible.",
      alejandroRole: "helped repair several glitches in the recovered build.",
      ruffleRole:
        "build and maintain the open-source Flash emulator that lets the preserved SWF run in modern browsers. This site hosts its own local Ruffle copy.",
      updateTitle: "Updates recorded on the preservation item (9/8/25)",
      updateItems: [
        "Fixed the invisible correct-sign glitch in Car Path.",
        "Added the Hexagon Path reset sequence from the iPhone version.",
        "Removed the obsolete landscape-only score board.",
        "Removed the upload-score pop-up.",
      ],
      creditNote:
        "We are only keeping another local copy. The credit for bringing the game back belongs to these preservation contributors and to everyone maintaining Ruffle.",
      archiveLink: "View the original preservation source",
      fallback: "JavaScript is required to run this game.",
    };
---

<p class="mb-6 text-lg leading-relaxed">{copy.intro}</p>

<section aria-labelledby="game-title">
  <h2 id="game-title" class="mb-4 text-2xl font-semibold">
    Who Has The Biggest Brain?
    <span class="text-muted-foreground font-normal">by Playfish (2009)</span>
  </h2>

  <div
    class="border-border overflow-hidden rounded-xl border bg-black shadow-2xl"
  >
    <div
      class="border-border flex items-center justify-between border-b bg-[#171923] px-4 py-3 text-sm text-white"
    >
      <div class="flex items-center gap-2" aria-hidden="true">
        <span class="size-3 rounded-full bg-[#ff5f57]"></span>
        <span class="size-3 rounded-full bg-[#febc2e]"></span>
        <span class="size-3 rounded-full bg-[#28c840]"></span>
      </div>
      <span class="font-medium tracking-wide">LOCAL FLASH PLAYER</span>
    </div>

    <div
      id="whtbb-player"
      class="flex aspect-[672/502] w-full items-center justify-center bg-black text-center text-sm text-white"
      data-swf-url={swfUrl}
      data-error-message={copy.loadError}
      aria-label="Who Has The Biggest Brain? — playable Flash game"
    >
      <button
        type="button"
        class="group relative block size-full cursor-pointer overflow-hidden bg-black focus-visible:outline-2 focus-visible:outline-offset-[-4px] focus-visible:outline-white"
        data-game-preview
        aria-label={copy.playLabel}
      >
        <img
          src={previewImage}
          alt=""
          width="672"
          height="502"
          class="size-full object-cover transition-transform duration-300 group-hover:scale-[1.01]"
          loading="eager"
          decoding="async"
        />
        <span
          class="absolute inset-0 flex items-center justify-center bg-black/5 transition-colors group-hover:bg-black/15"
          aria-hidden="true"
        >
          <span
            class="flex size-24 items-center justify-center rounded-full bg-black/75 shadow-2xl ring-2 ring-white/90 backdrop-blur-sm transition-transform group-hover:scale-105 sm:size-28"
          >
            <svg viewBox="0 0 64 64" class="ml-1 size-12 fill-white sm:size-14">
              <path d="M18 10v44l36-22z"></path>
            </svg>
          </span>
        </span>
        <span
          class="absolute bottom-4 left-1/2 -translate-x-1/2 rounded-full bg-black/75 px-4 py-2 font-semibold whitespace-nowrap text-white shadow-lg backdrop-blur-sm"
        >
          {copy.playLabel}
        </span>
      </button>
    </div>
  </div>

  <p class="text-muted-foreground mt-3 text-center text-sm">
    {copy.playHint}
  </p>

  <div class="mt-8 grid gap-4 sm:grid-cols-2">
    <div class="border-border rounded-lg border p-5">
      <h3 class="text-accent text-xl font-semibold">
        Who Has The Biggest Brain?
      </h3>
      <p class="mt-3 leading-relaxed">{copy.attribution}</p>
      <a
        href="https://archive.org/details/whtbb"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent mt-4 inline-block decoration-dashed underline-offset-4 hover:underline"
      >
        {copy.archiveLink}
        <span aria-hidden="true">&nearr;</span>
      </a>
    </div>

    <aside class="border-border bg-muted/30 rounded-lg border p-5">
      <h3 class="font-semibold">{copy.offlineTitle}</h3>
      <p class="text-muted-foreground mt-3 leading-relaxed">
        {copy.offlineNote}
      </p>
    </aside>
  </div>

  <section
    class="border-border bg-muted/20 mt-4 rounded-xl border p-5 sm:p-7"
    aria-labelledby="preservation-credits-title"
  >
    <h3
      id="preservation-credits-title"
      class="text-accent text-2xl font-semibold"
    >
      {copy.creditsTitle}
    </h3>
    <p class="mt-3 max-w-3xl leading-relaxed">{copy.creditsIntro}</p>

    <dl class="mt-6 grid gap-4 sm:grid-cols-2">
      <div class="border-border bg-background rounded-lg border p-4">
        <dt class="font-semibold">
          <a
            href="https://archive.org/details/@chuzzleado-games"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent decoration-dashed underline-offset-4 hover:underline"
          >
            PandaFake⚡
            <span aria-hidden="true">&nearr;</span>
          </a>
        </dt>
        <dd class="text-muted-foreground mt-2 leading-relaxed">
          {copy.pandaRole}
        </dd>
      </div>

      <div class="border-border bg-background rounded-lg border p-4">
        <dt class="font-semibold">BattleAncient (Rachid)</dt>
        <dd class="text-muted-foreground mt-2 leading-relaxed">
          {copy.rachidRole}
        </dd>
      </div>

      <div class="border-border bg-background rounded-lg border p-4">
        <dt class="font-semibold">floydian (Alejandro)</dt>
        <dd class="text-muted-foreground mt-2 leading-relaxed">
          {copy.alejandroRole}
        </dd>
      </div>

      <div class="border-border bg-background rounded-lg border p-4">
        <dt class="font-semibold">
          <a
            href="https://ruffle.rs/"
            target="_blank"
            rel="noopener noreferrer"
            class="text-accent decoration-dashed underline-offset-4 hover:underline"
          >
            Ruffle contributors
            <span aria-hidden="true">&nearr;</span>
          </a>
        </dt>
        <dd class="text-muted-foreground mt-2 leading-relaxed">
          {copy.ruffleRole}
        </dd>
      </div>
    </dl>

    <div class="border-border mt-6 border-t pt-6">
      <h4 class="font-semibold">{copy.updateTitle}</h4>
      <ul class="mt-3 list-disc space-y-2 ps-6">
        {copy.updateItems.map(item => <li>{item}</li>)}
      </ul>
    </div>

    <p class="text-muted-foreground mt-6 text-sm leading-relaxed">
      {copy.creditNote}
      <a
        href="https://archive.org/details/whtbb"
        target="_blank"
        rel="noopener noreferrer"
        class="text-accent ms-1 decoration-dashed underline-offset-4 hover:underline"
      >
        {copy.archiveLink}
        <span aria-hidden="true">&nearr;</span>
      </a>
    </p>
  </section>

  <noscript>
    <p class="mt-4">{copy.fallback}</p>
  </noscript>
</section>

<script is:inline src={ruffleScript}></script>
<script is:inline>
  (() => {
    const initializeGame = () => {
      const container = document.querySelector("#whtbb-player");

      if (!(container instanceof HTMLElement)) return;
      if (container.dataset.initialized === "true") return;
      if (container.dataset.previewBound === "true") return;

      const preview = container.querySelector("[data-game-preview]");
      if (!(preview instanceof HTMLButtonElement)) return;

      const showError = () => {
        container.dataset.initialized = "false";
        const message = document.createElement("p");
        message.className = "px-6";
        message.textContent =
          container.dataset.errorMessage || "The game could not load.";
        container.replaceChildren(message);
      };

      const startGame = () => {
        const ruffle = window.RufflePlayer?.newest?.();
        const swf = container.dataset.swfUrl;

        if (!ruffle || !swf) {
          showError();
          return;
        }

        container.dataset.initialized = "true";

        try {
          const player = ruffle.createPlayer();
          player.style.width = "100%";
          player.style.height = "100%";
          player.setAttribute(
            "aria-label",
            "Who Has The Biggest Brain? — playable Flash game"
          );
          container.replaceChildren(player);

          Promise.resolve(
            player.ruffle().load({
              url: swf,
              autoplay: "on",
              unmuteOverlay: "hidden",
              splashScreen: false,
            })
          ).catch(showError);
        } catch {
          showError();
        }
      };

      container.dataset.previewBound = "true";
      preview.addEventListener("click", startGame, { once: true });
    };

    initializeGame();

    if (!window.__goodOldGamePageLoadListener) {
      document.addEventListener("astro:page-load", initializeGame);
      window.__goodOldGamePageLoadListener = true;
    }
  })();
</script>
