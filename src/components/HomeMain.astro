---
import { getCollection } from "astro:content";
import { getRelativeLocaleUrl } from "astro:i18n";
import IconRss from "@/assets/icons/IconRss.svg";
import IconArrowRight from "@/assets/icons/IconArrowRight.svg";
import Socials from "@/components/Socials.astro";
import Card from "@/components/Card.astro";
import LinkButton from "@/components/LinkButton.astro";
import { getSortedPosts } from "@/utils/getSortedPosts";
import { filterByLang } from "@/utils/locale";
import { useTranslations } from "@/i18n";
import config from "@/config";

const { socials, posts: postsConfig } = config;

const locale = Astro.currentLocale ?? config.site.lang;
const t = useTranslations(locale);

const posts = filterByLang(await getCollection("posts"), locale);
const sortedPosts = getSortedPosts(posts);
const featuredPosts = sortedPosts.filter(({ data }) => data.featured);
const recentPosts = sortedPosts.filter(({ data }) => !data.featured);
const homePath = getRelativeLocaleUrl(locale, "");
const rssHref = getRelativeLocaleUrl(locale, "rss.xml");
---

<main
  id="main-content"
  data-layout="index"
  data-home-path={homePath}
  class="app-layout"
>
  <section id="hero" class="border-border border-b pt-8 pb-6">
    <h1 class="my-4 inline-block text-4xl font-bold sm:my-8 sm:text-5xl">
      {t.hero.title}
    </h1>
    <a
      target="_blank"
      href={rssHref}
      class="inline-block"
      aria-label="RSS Feed"
      title="RSS Feed"
    >
      <IconRss
        width={20}
        height={20}
        class="stroke-accent scale-125 stroke-3 rtl:-rotate-90"
      />
      <span class="sr-only">RSS Feed</span>
    </a>

    <p class="text-muted-foreground mb-3 font-medium">{t.hero.tagline}</p>
    <p>
      {t.hero.rolePre}<LinkButton
        class="hover:text-accent underline decoration-dashed underline-offset-4"
        href="https://wistkey.com"
      >
        {t.hero.roleLink}
      </LinkButton>{t.hero.rolePost}
    </p>
    <p class="mt-2">{t.hero.writing}</p>

    <div class="mt-4 flex flex-wrap gap-3">
      <LinkButton
        href={getRelativeLocaleUrl(locale, "projects")}
        class="hover:text-accent underline decoration-dashed underline-offset-4"
      >
        {t.hero.ctaProjects}
        <IconArrowRight class="inline-block size-4 rtl:-rotate-180" />
      </LinkButton>
      <LinkButton
        href={getRelativeLocaleUrl(locale, "about")}
        class="hover:text-accent underline decoration-dashed underline-offset-4"
      >
        {t.hero.ctaAbout}
        <IconArrowRight class="inline-block size-4 rtl:-rotate-180" />
      </LinkButton>
    </div>

    {
      socials.length > 0 && (
        <div class="mt-4 flex max-sm:flex-col sm:items-center">
          <div class="me-2 mb-1 whitespace-nowrap sm:mb-0">
            {t.home.socialLinks}:
          </div>
          <Socials />
        </div>
      )
    }
  </section>

  {
    featuredPosts.length > 0 && (
      <section
        id="featured"
        class:list={[
          "pt-12 pb-6",
          { "border-border border-b": recentPosts.length > 0 },
        ]}
      >
        <h2 class="text-2xl font-semibold tracking-wide">{t.home.featured}</h2>
        <ul>
          {featuredPosts.map(data => (
            <Card variant="h3" {...data} />
          ))}
        </ul>
      </section>
    )
  }

  {
    recentPosts.length > 0 && (
      <section id="recent-posts" class="pt-12 pb-6">
        <h2 class="text-2xl font-semibold tracking-wide">
          {t.home.recentPosts}
        </h2>
        <ul>
          {recentPosts.slice(0, postsConfig.perIndex).map(data => (
            <Card variant="h3" {...data} />
          ))}
        </ul>
      </section>
    )
  }

  <div class="my-8 text-center">
    <LinkButton href={getRelativeLocaleUrl(locale, "posts")}>
      {t.home.allPosts}
      <IconArrowRight class="inline-block rtl:-rotate-180" />
    </LinkButton>
  </div>
</main>

<script>
  document.addEventListener("astro:page-load", () => {
    const indexLayout = (document.querySelector("#main-content") as HTMLElement)
      ?.dataset;
    const baseRoot = import.meta.env.BASE_URL.replace(/\/?$/, "/");
    if (indexLayout?.layout) {
      sessionStorage.setItem("backUrl", indexLayout.homePath ?? baseRoot);
    }
  });
</script>
