---
import config from "@/config";

const sameAs = config.socials
  .map(social => social.url)
  .filter(url => url !== "#" && !url.startsWith("mailto:"));

const personLd = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: "Nam Chan",
  alternateName: ["Alfred Nam", "Kwun Nam Chan"],
  url: config.site.url,
  jobTitle: "Chief Technology Officer",
  worksFor: {
    "@type": "Organization",
    name: "Wistkey",
    url: "https://wistkey.com",
  },
  knowsLanguage: ["en", "zh-Hant"],
  ...(sameAs.length > 0 && { sameAs }),
};
---

<script type="application/ld+json" is:inline set:html={JSON.stringify(personLd)}
></script>
