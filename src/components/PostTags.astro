---
import Tag from "@/components/Tag.astro";

type TagItem = {
  tag: string;
  tagName: string;
};

type Props = {
  tags: TagItem[];
  title: string;
  description: string;
};

const { tags, title, description } = Astro.props;
---

<section class="app-layout mt-6 mb-10" aria-labelledby="post-tags-title">
  <div class="border-border border-t pt-8">
    <h2 id="post-tags-title" class="text-2xl font-semibold sm:text-3xl">
      {title}
    </h2>
    <p class="mt-2 mb-6 italic">{description}</p>
    <ul class="flex flex-wrap gap-6">
      {tags.map(({ tag, tagName }) => <Tag {tag} {tagName} />)}
    </ul>
  </div>
</section>
