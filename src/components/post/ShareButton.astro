---
import { useTranslations } from "@/i18n";
import config from "@/config";

type Props = {
  targetId: string;
};

const { targetId } = Astro.props;
const t = useTranslations(Astro.currentLocale ?? config.site.lang);
---

<button
  type="button"
  data-share-trigger
  aria-controls={targetId}
  aria-haspopup="dialog"
  class="border-border bg-background hover:border-accent hover:text-accent inline-flex items-center gap-2 rounded-lg border px-4 py-2.5 font-semibold transition-colors"
>
  <svg
    aria-hidden="true"
    viewBox="0 0 24 24"
    class="size-5 fill-none stroke-current stroke-2"
  >
    <circle cx="18" cy="5" r="3"></circle>
    <circle cx="6" cy="12" r="3"></circle>
    <circle cx="18" cy="19" r="3"></circle>
    <path d="m8.6 10.5 6.8-4M8.6 13.5l6.8 4"></path>
  </svg>
  {t.post.shareButton}
</button>
